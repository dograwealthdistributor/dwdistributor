<!DOCTYPE html>
<html>
<head>
<title>Lumpsum Calculator India</title>
<meta name="description" content="One time investment returns calculator">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body style="text-align:center;font-family:Arial;">

<h2>Lumpsum Calculator</h2>

<input id="amount" placeholder="Investment"><br>
<input id="rate" placeholder="Return %"><br>
<input id="years" placeholder="Years"><br>

<button onclick="calc()">Calculate</button>

<p id="output"></p>
<canvas id="chart"></canvas>

<h3>How to Use</h3>
<p>Enter amount, return rate and years.</p>

<script>
let chart;
function calc(){
let P=amount.value,r=rate.value/100,n=years.value;
let FV=P*Math.pow(1+r,n);

output.innerHTML="Invested: ₹"+P+" Final: ₹"+Math.round(FV);

if(chart) chart.destroy();
chart=new Chart(chart,{type:'pie',data:{labels:['Invested','Gain'],datasets:[{data:[P,FV-P]}]}});
}
</script>

</body>
</html>
