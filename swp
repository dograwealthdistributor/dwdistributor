<!DOCTYPE html>
<html>
<head>
<title>SWP Calculator India</title>
<meta name="description" content="Monthly income calculator from mutual funds">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body style="text-align:center;font-family:Arial;">

<h2>SWP Calculator</h2>

<input id="corpus" placeholder="Total Investment"><br>
<input id="withdrawal" placeholder="Monthly Withdrawal"><br>
<input id="rate" placeholder="Return %"><br>
<input id="years" placeholder="Years"><br>

<button onclick="calc()">Calculate</button>

<p id="output"></p>
<canvas id="chart"></canvas>

<h3>How to Use</h3>
<p>Enter investment, withdrawal, return rate and years.</p>

<script>
let chart;
function calc(){
let corpus=Number(corpus.value);
let withdrawal=Number(withdrawal.value);
let rate=Number(rate.value)/100/12;
let months=years.value*12;

let balance=corpus,total=0;

for(let i=0;i<months;i++){
balance*=1+rate;
if(balance<withdrawal){total+=balance;balance=0;break;}
balance-=withdrawal;total+=withdrawal;
}

output.innerHTML="Withdrawn: ₹"+Math.round(total)+" Remaining: ₹"+Math.round(balance);

if(chart) chart.destroy();
chart=new Chart(chart,{type:'pie',data:{labels:['Withdrawn','Remaining'],datasets:[{data:[total,balance]}]}});
}
</script>

</body>
</html>
